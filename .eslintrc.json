{
  "extends": "next/core-web-vitals",
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "uploads/",
    "backups/",
    ".logs/",
    "tests/.tmp/"
  ],
  "overrides": [
    {
      "files": ["bot/**/*.mjs"],
      "env": { "node": true, "es2022": true },
      "parserOptions": { "ecmaVersion": 2022, "sourceType": "module" },
      "rules": {
        "@next/next/no-html-link-for-pages": "off"
      }
    }
  ]
}
