// ProjectHub — Prisma schema
// ---------------------------------------------------------------------------
// Default provider is SQLite: one file, zero config, perfect for a Pi.
//
// To switch to PostgreSQL:
//   1. Change `provider = "sqlite"` below to `provider = "postgresql"`.
//   2. Point DATABASE_URL (in .env) at your Postgres connection string.
//   3. Run `npm run db:push`.
// Everything else stays the same — that's the beauty of Prisma.
//
// NOTE: SQLite has no native enum type, so status/priority/severity fields are
// stored as plain strings. Allowed values are validated in the app layer and
// centralised in lib/constants.ts (the single source of truth for the UI too).
// ---------------------------------------------------------------------------

generator client {
  provider      = "prisma-client-js"
  // "native" builds the engine for the machine you run `prisma generate` on.
  // If you build on a PC and deploy to a Pi, add "linux-arm64-openssl-3.0.x".
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  username     String?  @unique // handle for @mentions / display
  email        String   @unique
  passwordHash String
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Telegram account linking
  telegramChatId   String?   @unique
  telegramLinkedAt DateTime?

  // Notification preferences
  notifyMorning   Boolean @default(true) // "what's due today" report
  morningHour     Int     @default(7) // 0-23, local time
  notifyEvening   Boolean @default(true) // "what's due tomorrow" report
  eveningHour     Int     @default(20)
  notifyAssigned  Boolean @default(true)
  notifyComments  Boolean @default(true)
  notifyMentions  Boolean @default(true)
  notifyReminders Boolean @default(true)

  // Appearance
  accentColor String? // accent preset key (see lib/accents.ts)

  projects     Project[]
  tasks        Task[]
  bugs         Bug[]
  notes        Note[]
  activityLogs ActivityLog[]

  // multi-user
  memberships    ProjectMember[]
  assignedTasks  Task[]              @relation("AssignedTasks")
  comments       Comment[]
  notifications  Notification[]
  telegramTokens TelegramLinkToken[]
  timeEntries    TimeEntry[]
  attachments    Attachment[]
}

model Attachment {
  id         String   @id @default(cuid())
  filename   String // original display name
  storedName String // name on disk (uploads/)
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([projectId])
  @@index([userId])
}

model TimeEntry {
  id        String   @id @default(cuid())
  seconds   Int
  startedAt DateTime
  endedAt   DateTime @default(now())
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endedAt])
  @@index([taskId])
}

model TelegramLinkToken {
  id        String   @id @default(cuid())
  code      String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  role      String   @default("MEMBER") // OWNER | ADMIN | MEMBER | VIEWER
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Notification {
  id         String   @id @default(cuid())
  type       String // ASSIGNED | DUE | OVERDUE | MENTION | STATUS | PROJECT | COMMENT
  title      String
  body       String?
  entityType String?
  entityId   String?
  read       Boolean  @default(false)
  pushed     Boolean  @default(false) // delivered to Telegram yet?
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([pushed])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("PLANNING") // PLANNING | ACTIVE | ON_HOLD | COMPLETED
  priority    String    @default("MEDIUM")    // LOW | MEDIUM | HIGH | CRITICAL
  progress    Int       @default(0)            // 0–100
  color       String?                          // optional accent (hex), used in UI
  tags        String    @default("")           // comma-separated (SQLite has no arrays)
  startDate   DateTime?
  dueDate     DateTime?
  deletedAt   DateTime?                     // soft delete (Trash)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks      Task[]
  bugs       Bug[]
  notes      Note[]
  milestones  Milestone[]
  members     ProjectMember[]
  attachments Attachment[]

  @@index([userId])
  @@index([status])
}

model Milestone {
  id        String    @id @default(cuid())
  title     String
  completed Boolean   @default(false)
  order     Int       @default(0)
  dueDate   DateTime?
  createdAt DateTime  @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO")   // TODO | IN_PROGRESS | REVIEW | DONE
  priority    String    @default("MEDIUM")  // LOW | MEDIUM | HIGH | CRITICAL
  dueDate     DateTime?
  notes       String?
  order       Int       @default(0)         // position within a board column
  completedAt DateTime?
  recurrence         String?   // DAILY | WEEKLY | MONTHLY (null = one-off)
  recurrenceInterval Int       @default(1) // repeat every N units
  recurrenceUntil    DateTime?             // stop repeating after this date
  timeSpent      Int       @default(0)      // accumulated tracked seconds
  timerStartedAt DateTime?                  // set while a timer is running
  deletedAt   DateTime?                     // soft delete (Trash)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tasks may be standalone (no project) or tied to one. Deleting a project
  // unassigns its tasks rather than destroying them.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // multi-user: who the task is assigned to (defaults to the creator)
  assigneeId String?
  assignee   User?   @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)

  subtasks    Subtask[]
  comments    Comment[]
  timeEntries TimeEntry[]
  attachments Attachment[]

  @@index([userId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Bug {
  id               String    @id @default(cuid())
  title            String
  description      String?
  severity         String    @default("MINOR") // MINOR | MAJOR | CRITICAL
  status           String    @default("OPEN")  // OPEN | INVESTIGATING | FIXED | CLOSED
  stepsToReproduce String?
  fixNotes         String?
  resolvedAt       DateTime?
  deletedAt        DateTime?               // soft delete (Trash)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([status])
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("") // markdown
  pinned    Boolean  @default(false)
  deletedAt DateTime?              // soft delete (Trash)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // created | updated | completed | deleted | reopened ...
  entityType  String   // project | task | bug | note
  entityId    String?
  entityTitle String   // snapshot of the title at the time, for display
  meta        String?  // optional JSON blob (stringified)
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
